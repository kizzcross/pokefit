# Copie para deploy/.env e preencha os valores.
# cp .env.production.example .env

# --- Django ---
DJANGO_SETTINGS_MODULE=pokefit.settings.production
SECRET_KEY=CHANGE_ME_use_python_get_random_secret_key
ALLOWED_HOSTS=pokefit.kizzcross.com.br,178.105.169.230

# Domínio público (HTTPS após Certbot)
HOST=https://pokefit.kizzcross.com.br

ADMIN_ENVIRONMENT_LABEL=Production
ADMIN_ENVIRONMENT_COLOR=#ffffff
ADMIN_ENVIRONMENT_BACKGROUND_COLOR=#dc2626

# --- Banco (serviço db no compose) ---
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DATABASE_URL=postgres://pokefit:CHANGE_ME_strong_db_password@db:5432/pokefit

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDBEAT_REDIS_URL=redis://redis:6379/1

# --- Email (SendGrid — obrigatório em production.py) ---
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=CHANGE_ME_sendgrid_api_key

# --- Opcional ---
SENTRY_DSN=
RENDER_GIT_COMMIT=
GUNICORN_WORKERS=3
